# Override the API server URL for the Vite dev frontend (optional)
# Defaults to relative URLs (proxied by Vite to http://localhost:3001)
# VITE_API_URL=http://localhost:3001

# Directory where parks.db is stored (optional, defaults to project root)
# Set to /data in Docker
# DATA_DIR=/data

# Port the Express API server listens on (optional, defaults to 3001)
# PORT=3001
